VARA_WS_ENDPOINT=wss://testnet.vara.network
RELAYER_MNEMONIC=

# Finality Oracle: MUST be true to send chain txs (submit_round, settle, start).
# Preferred:
# FINALITY_ORACLE_SEND_TXS=true
# Legacy alias (still accepted):
# ROUND_MANAGER_SEND_TXS=true
# Ms after settle before start_round — claim window while Resolved (default 60000 in code; use 180000 on mainnet if needed).
# SETTLE_TO_START_DELAY_MS=60000
# Retry cooldown tuning (ms):
# START_RETRY_COOLDOWN_MS=180000
# START_RETRY_COOLDOWN_TOO_EARLY_MS=5000
# START_RETRY_COOLDOWN_INSUFFICIENT_MS=900000
# In rolling mode, `settle_roll` errors use the same cooldown buckets.
# Max intents to schedule per scan (keeps queues short, prioritizes fresh expiries)
# ORCHESTRATOR_ACTIONS_PER_SCAN=12
# Minimum start intents reserved per scan so starts are not starved by settle backlog
# Used only in legacy mode; rolling mode does not reserve per-scan start slots.
# ORCHESTRATOR_MIN_START_ACTIONS_PER_SCAN=2

# Rolling mode is configured in config/oracle.config.json:
#   "roundMode": "rolling"
#   "roundSeconds": 300
#   "combinedSettleRoll": false
# When combinedSettleRoll=true, orchestrator uses SettleAndRollWithTick (single tx per epoch)
# and requires the contract entrypoint to be deployed.

# After market program is deployed:
MARKET_PROGRAM_ID=
DRY_RUN=false

# One-time: Fin.init + register_asset — required for the web FIN faucet (npm run bootstrap:market from repo root)
BOOTSTRAP_MNEMONIC=
# ROUND_SECONDS=300
# MAX_ORACLE_AGE_SECS=120
# BOOTSTRAP_GAS_LIMIT=500000000000
# Floor for sendMessage gas (RPC min_limit can be too low for Fin.init / register_asset)
# BOOTSTRAP_HANDLE_MIN_GAS=250000000000
# Fin.init uses block gas limit (750e9 on testnet) by default — set to 0/false to use floored simulate instead
# BOOTSTRAP_INIT_USE_BLOCK_GAS=1
# SKIP_INIT=0
# SKIP_REGISTER=0

# Optional override path to oracle.config.json
# ORACLE_CONFIG=../../config/oracle.config.json

ORACLE_GAS_LIMIT=250000000000
